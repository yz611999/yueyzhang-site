---
import Base from '../layouts/Base.astro';
import DoodleStar from '../components/DoodleStar.astro';
import DoodleArrow from '../components/DoodleArrow.astro';
import DoodleSquiggle from '../components/DoodleSquiggle.astro';
import { getCollection } from 'astro:content';
import { quotes } from '../data/quotes';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<Base title="Home" description="Yuhang Zhang — lover of ideas, humantiy, art. Investing at M12.">

  <!-- ── HERO ── -->
  <section class="relative py-12 sm:py-20">
    <!-- Doodle decorations -->
    <DoodleStar color="#FF6B35" size={36} class="absolute top-4 right-8 opacity-80 rotate-12" />
    <DoodleStar color="#6BCB77" size={24} class="absolute top-16 right-24 opacity-60 -rotate-6" />
    <DoodleStar color="#FF6B35" size={20} class="absolute top-8 left-4 opacity-50 rotate-45" />

    <!-- Rotating quote panel (right side on large screens) -->
    <div id="quote-panel" class="hidden lg:block absolute right-0 top-8 w-72">
      <div class="font-display text-sm text-gray-400 mb-2 flex items-center gap-1">
        <DoodleSquiggle color="#B8D4E8" />
        <span>from the classics</span>
      </div>
      <!-- Graph-lined notecard -->
      <div class="card-sketch rotate-pos-1 relative overflow-hidden" style="background: white; min-height: 160px;">
        <!-- Horizontal graph lines inside card -->
        <div class="absolute inset-0 pointer-events-none" style="background-image: repeating-linear-gradient(to bottom, transparent, transparent 27px, #bfdbfe 27px, #bfdbfe 28px); background-position: 0 8px;"></div>
        <div class="relative z-10 p-5 pt-4">
          <p id="quote-text" class="quote-handwritten text-gray-900 leading-[28px] min-h-[84px]"></p>
          <p id="quote-author" class="quote-author text-[#FF6B35] mt-2 text-sm"></p>
        </div>
        <!-- Eraser overlay -->
        <div id="eraser" class="absolute inset-0 pointer-events-none opacity-0" style="background: white;"></div>
      </div>
    </div>

    <div class="max-w-2xl">
      <!-- Name -->
      <div class="flex items-center gap-3 mb-2">
        <h1 class="font-display text-6xl sm:text-7xl font-bold text-black leading-tight">
          Yuhang Zhang
        </h1>
      </div>

      <!-- Tagline -->
      <div class="flex items-center gap-3 mb-6">
        <DoodleSquiggle color="#FF6B35" />
        <p class="font-display text-2xl sm:text-3xl font-semibold text-[#FF6B35]">
          lover of ideas &amp; humanity &amp; art ✦
        </p>
      </div>

      <!-- Bio -->
      <div class="card-sketch rotate-neg-1 p-6 mb-8 max-w-xl">
        <p class="font-body text-lg text-gray-800 leading-relaxed">
          Currently building in SF 🌉<br />
          <strong>Investing at M12</strong> (Microsoft's VC fund) by day,<br />
          <strong>rewriting the world</strong> by night.<br /><br />
          Just trying to make the world a more beautiful place.
        </p>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-wrap items-center gap-4">
        <a href="/projects" class="btn-sketch btn-green">
          🛠 Projects
        </a>
        <DoodleArrow color="#6BCB77" />
        <a href="/writing" class="btn-sketch btn-orange">
          ✍️ Writing
        </a>
        <DoodleArrow color="#FF6B35" />
        <a href="https://linkedin.com/in/yuhangzhang99" target="_blank" rel="noopener" class="btn-sketch btn-white">
          LinkedIn ↗
        </a>
      </div>
    </div>
  </section>

  <!-- ── DIVIDER ── -->
  <div class="flex items-center gap-4 my-10">
    <div class="flex-1 border-t-2 border-black"></div>
    <DoodleStar color="#6BCB77" size={28} />
    <div class="flex-1 border-t-2 border-black"></div>
  </div>

  <!-- ── RECENT WRITING ── -->
  {recentPosts.length > 0 && (
    <section class="mb-12">
      <h2 class="font-display text-4xl font-bold mb-6 flex items-center gap-3">
        Recent Writing
        <DoodleSquiggle color="#B8D4E8" class="hidden sm:block" />
      </h2>
      <div class="grid gap-5">
        {recentPosts.map((post, i) => (
          <a
            href={`/writing/${post.slug}`}
            class={`card-sketch p-5 block no-underline group ${
              i % 3 === 0 ? 'rotate-neg-1' : i % 3 === 1 ? 'rotate-pos-1' : 'rotate-neg-2'
            }`}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-display text-2xl font-semibold text-black group-hover:text-[#FF6B35] transition-colors">
                  {post.data.title}
                </h3>
                <p class="font-body text-gray-600 mt-1 text-sm">{post.data.description}</p>
                <div class="flex flex-wrap gap-2 mt-2">
                  {post.data.tags.map(tag => (
                    <span class="text-xs font-body px-2 py-0.5 bg-[#B8D4E8]/40 border border-[#B8D4E8] rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <span class="font-body text-sm text-gray-400 shrink-0 mt-1">
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              </span>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-6">
        <a href="/writing" class="btn-sketch btn-white font-display text-lg">
          All posts →
        </a>
      </div>
    </section>
  )}


<script define:vars={{ quotes }}>
  const textEl = document.getElementById('quote-text');
  const authorEl = document.getElementById('quote-author');
  const eraser = document.getElementById('eraser');
  let current = 0;
  let writeTimer = null;

  // Write text character by character with slight random speed variation (pencil feel)
  function writeText(text, onDone) {
    textEl.textContent = '';
    let i = 0;
    function writeNext() {
      if (i >= text.length) { onDone && onDone(); return; }
      textEl.textContent += text[i];
      i++;
      // Slight rhythm variation — pause longer on punctuation
      const ch = text[i - 1];
      const delay = ['.', ',', '!', '?'].includes(ch) ? 120 + Math.random() * 80
                  : [' '].includes(ch) ? 40 + Math.random() * 20
                  : 30 + Math.random() * 30;
      writeTimer = setTimeout(writeNext, delay);
    }
    writeNext();
  }

  // Write author in after quote finishes
  function writeAuthor(text) {
    authorEl.textContent = '';
    let i = 0;
    function next() {
      if (i >= text.length) return;
      authorEl.textContent += text[i++];
      setTimeout(next, 25 + Math.random() * 20);
    }
    setTimeout(next, 300);
  }

  // Eraser: sweep a white block left→right across the card, then clear
  function eraseAndNext() {
    eraser.style.transition = 'none';
    eraser.style.opacity = '1';
    eraser.style.transform = 'translateX(-100%)';
    // Force reflow
    eraser.getBoundingClientRect();
    eraser.style.transition = 'transform 0.8s cubic-bezier(0.4,0,0.2,1)';
    eraser.style.transform = 'translateX(0%)';

    setTimeout(() => {
      textEl.textContent = '';
      authorEl.textContent = '';
      // Slide eraser back off to the right
      eraser.style.transition = 'transform 0.4s ease-in';
      eraser.style.transform = 'translateX(100%)';
      setTimeout(() => {
        eraser.style.opacity = '0';
        eraser.style.transform = 'translateX(-100%)';
        current = (current + 1) % quotes.length;
        showQuote();
      }, 420);
    }, 900);
  }

  function showQuote() {
    const q = quotes[current];
    writeText(q.text, () => writeAuthor('— ' + q.author));
  }

  // Start first quote, cycle every 30s
  showQuote();
  setInterval(eraseAndNext, 30000);
</script>
</Base>
