---
export interface Props {
  color?: string;
  size?: number;
  class?: string;
}
const { color = '#6BCB77', size = 48, class: cls = '' } = Astro.props;
---
<svg width={size} height={size * 0.5} viewBox="0 0 48 24" fill="none" xmlns="http://www.w3.org/2000/svg" class={cls} aria-hidden="true">
  <!-- Sketchy arrow -->
  <path
    d="M2 12 C8 11, 14 13, 20 12 C26 11, 32 13, 36 12"
    stroke={color}
    stroke-width="2.5"
    stroke-linecap="round"
  />
  <path
    d="M32 6 L38 12 L32 18"
    stroke={color}
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
