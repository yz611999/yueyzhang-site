---
export interface Props {
  color?: string;
  class?: string;
}
const { color = '#B8D4E8', class: cls = '' } = Astro.props;
---
<svg width="80" height="16" viewBox="0 0 80 16" fill="none" xmlns="http://www.w3.org/2000/svg" class={cls} aria-hidden="true">
  <path
    d="M2 8 C8 3, 14 13, 20 8 C26 3, 32 13, 38 8 C44 3, 50 13, 56 8 C62 3, 68 13, 74 8"
    stroke={color}
    stroke-width="2.5"
    stroke-linecap="round"
  />
</svg>
