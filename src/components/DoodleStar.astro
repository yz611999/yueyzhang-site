---
export interface Props {
  color?: string;
  size?: number;
  class?: string;
}
const { color = '#FF6B35', size = 32, class: cls = '' } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class={cls} aria-hidden="true">
  <!-- Hand-drawn star (slightly imperfect) -->
  <path
    d="M16 3 L18.2 11.5 L27 10 L21 16.5 L24 25 L16 20.5 L8 25 L11 16.5 L5 10 L13.8 11.5 Z"
    fill={color}
    stroke="#111"
    stroke-width="1.5"
    stroke-linejoin="round"
    stroke-linecap="round"
  />
</svg>
